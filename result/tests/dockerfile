FROM alpine:3.19

WORKDIR /app

COPY . .

RUN apk add --no-cache \
    bash \
    postgresql-client \
    curl



CMD [ "chmod", "+x", "tests.sh" ]

ENTRYPOINT [ "./tests.sh" ]







